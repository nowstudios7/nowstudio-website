{
  "version": 2,
  "public": true,
  "buildCommand": "echo 'Static HTML - no build needed'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "/index.html"
    },
    {
      "src": "/.*",
      "dest": "/$0"
    }
  ]
}
